<?xml version="1.0" encoding="utf-8"?>
<!-- Splash screen background with centered logo. Uses bitmap gravity instead of item width/height (which require API 23+) -->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:drawable="@color/dark" />
    <item>
        <bitmap
            android:src="@drawable/logo_stripe"
            android:gravity="center" />
    </item>
</layer-list>
